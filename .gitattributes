# Git LFS attributes
# 如果需要使用 Git LFS 管理大文件，可以在这里配置

# 指定需要 LFS 管理的文件类型
# *.png filter=lfs diff=lfs merge=lfs -text
# *.jpg filter=lfs diff=lfs merge=lfs -text
# *.mp3 filter=lfs diff=lfs merge=lfs -text
# *.m4a filter=lfs diff=lfs merge=lfs -text

# 文本文件使用统一的换行符
*.swift text eol=lf
*.h text eol=lf
*.m text eol=lf
*.plist text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.sh text eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.storyboard binary
*.xcassets binary

# 不跟踪的文件
*.xcuserstate
*.xccheckout
*.moved-aside
*.xcuserstate
